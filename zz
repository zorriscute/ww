local function getHWID()
    local hwid
    if syn and syn.crypt and syn.crypt.custom and syn.crypt.custom.hash then
        hwid = syn.crypt.custom.hash(tostring(game.PlaceId) .. tostring(LocalPlayer.UserId))
    elseif game:GetService("RbxAnalyticsService") then
        hwid = game:GetService("RbxAnalyticsService"):GetClientId()
    else
        hwid = tostring(game.PlaceId) .. tostring(LocalPlayer.UserId) .. tostring(os.time())
    end
    return tostring(hwid)
end

local hwid = getHWID()
local isWhitelisted = false
for _, w in ipairs(WHITELISTED_HWIDS) do
    if string.lower(tostring(w)) == string.lower(hwid) then
        isWhitelisted = true
        break
    end
end

if not isWhitelisted then
    pcall(function()
        if setclipboard then setclipboard(hwid) end
        if toclipboard then toclipboard(hwid) end
    end)
    StarterGui:SetCore("SendNotification", {
        Title = "HWID Not Whitelisted",
        Text = "Your HWID has been copied to clipboard. Send it to the owner to get whitelisted.",
        Duration = 10
    })
    task.wait(2)
    game:Shutdown()
end
